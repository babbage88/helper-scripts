		{
			"src": ["192.168.8.0/24"],
			"dst": ["*"],
			"ip":  ["*"],
		},
		{
			"src": ["ipset:lan-subnets"],
			"dst": ["*"],
			"ip":  ["*"],
		},
		{
			"src": ["10.0.0.0/23", "10.2.0.0/16"],
			"dst": ["100.64.0.0/10"],
			"ip":  ["*"],
